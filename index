<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="utf-8">
  <title>ระบบบันทึกรายรับ-รายจ่าย</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Kanit:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  
  <script src="https://www.gstatic.com/firebasejs/8.10.1/firebase-app.js"></script>
  <script src="https://www.gstatic.com/firebasejs/8.10.1/firebase-database.js"></script>

  <style>
    :root {
      --main-color: #96a9ee;
      --main-color-dark: #7a8ecf;
    }
    body {
      font-family: 'Kanit', sans-serif;
      background-color: #121212;
      color: #e0e0e0;
      -webkit-user-select: none;
      user-select: none;
      overflow: hidden;
      position: fixed;
      width: 100%;
      height: 100%;
    }
    .scroll-container {
      height: 100%;
      overflow-y: auto;
      -webkit-overflow-scrolling: touch;
      padding-bottom: 100px;
    }
    .custom-card {
      background-color: #1e1e1e;
      border: 1px solid #2d2d2d;
      border-radius: 16px;
    }
    .dropdown-list {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      z-index: 50;
      background: #2a2a2a;
      border: 1px solid #444;
      border-radius: 8px;
      max-height: 160px;
      overflow-y: auto;
      box-shadow: 0 4px 15px rgba(0,0,0,0.5);
    }
    .fire-loading {
      position: fixed;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      z-index: 9999;
      font-size: 4rem;
      color: #ff5722;
      animation: fire-pulse 0.8s infinite alternate ease-in-out;
      pointer-events: none;
    }
    @keyframes fire-pulse {
      0% { transform: translate(-50%, -50%) scale(0.9); filter: drop-shadow(0 0 10px #ff9800); }
      100% { transform: translate(-50%, -50%) scale(1.2); filter: drop-shadow(0 0 25px #ff5722); }
    }
    input[type="date"]::-webkit-calendar-picker-indicator {
      filter: invert(1);
    }
    .lock-date-input::-webkit-calendar-picker-indicator {
      filter: invert(0) !important;
    }
  </style>
</head>
<body class="p-4">

  <div id="loadingOverlay" class="hidden">
    <i class="fa-solid fa-fire-flame-curved fire-loading"></i>
  </div>

  <div id="lockScreen" class="fixed inset-0 bg-[#121212] z-40 flex flex-col items-center justify-center p-6 hidden">
    <div class="custom-card p-8 w-full max-w-sm flex flex-col items-center text-center space-y-6">
      <i class="fa-solid fa-circle-check text-[var(--main-color)] text-6xl"></i>
      <h2 class="text-2xl font-medium text-white">ส่งข้อมูลแล้ว</h2>
      <div class="w-full flex justify-center">
        <input type="date" id="lockDateInput" onchange="changeDateFromInput(this.value)"
               class="lock-date-input bg-[#e0e0e0] text-black text-center font-bold py-3 px-4 rounded-xl border-none focus:outline-none focus:ring-2 focus:ring-[var(--main-color)] w-full max-w-[200px] shadow-inner">
      </div>
      <button onclick="unlockForEdit()" class="w-full py-3.5 bg-gray-700 hover:bg-gray-600 text-white font-medium rounded-xl flex items-center justify-center gap-2 transition">
        <i class="fa-solid fa-lock-open"></i> ปลดล็อคเพื่อแก้ไข
      </button>
    </div>
  </div>

  <div id="successModal" class="fixed inset-0 bg-black/80 z-50 flex items-center justify-center p-4 hidden">
    <div class="custom-card p-6 w-full max-w-sm flex flex-col items-center text-center space-y-5">
      <i class="fa-solid fa-circle-check text-[var(--main-color)] text-5xl"></i>
      <h3 class="text-xl font-medium text-white" id="successText">บันทึกเรียบร้อย!</h3>
      <button onclick="nextDayAction()" class="w-full py-4 bg-[var(--main-color)] hover:bg-[var(--main-color-dark)] text-black font-bold rounded-xl text-lg flex items-center justify-center gap-2 shadow-lg transition">
        <i class="fa-solid fa-calendar-plus"></i> ทำรายการวันถัดไป
      </button>
      <button onclick="closeSuccessModal()" class="w-full py-2.5 bg-transparent text-gray-400 hover:text-white font-medium rounded-xl text-sm border border-gray-700 transition">
        <i class="fa-solid fa-pen-to-square"></i> แก้ไขข้อมูล
      </button>
    </div>
  </div>

  <div class="scroll-container max-w-md mx-auto space-y-5">
    <div class="custom-card p-4 flex flex-col space-y-2 shadow-sm">
      <label class="text-sm font-medium text-gray-400 flex items-center gap-2">
        <i class="fa-regular fa-calendar text-[var(--main-color)]"></i> วันที่ทำรายการ
      </label>
      <div class="flex justify-center">
        <input type="date" id="dateInput" onchange="onDateChange()" 
               class="bg-[#2d2d2d] text-center text-white font-semibold py-3 px-4 rounded-xl border border-gray-600 focus:outline-none focus:border-[var(--main-color)] w-full shadow-inner">
      </div>
    </div>

    <div class="custom-card p-4 space-y-4 shadow-sm">
      <h3 class="text-md font-semibold text-gray-200 flex items-center gap-2 border-b border-gray-800 pb-2">
        <i class="fa-solid fa-wallet text-[var(--main-color)]"></i> รายรับ
      </h3>
      <div class="space-y-3">
        <div class="flex flex-col space-y-1">
          <label class="text-xs text-gray-400">เงินสด</label>
          <input type="number" id="cashInput" onchange="saveDraftToFirebase()" placeholder="กรอกยอดเงินสด"
                 class="w-full bg-[#2d2d2d] text-white p-3 rounded-xl border border-gray-700 focus:outline-none focus:border-[var(--main-color)] text-right font-medium text-lg">
        </div>
        <div class="flex flex-col space-y-1">
          <label class="text-xs text-gray-400">เงินโอน</label>
          <input type="number" id="transferInput" onchange="saveDraftToFirebase()" placeholder="กรอกยอดเงินโอน"
                 class="w-full bg-[#2d2d2d] text-white p-3 rounded-xl border border-gray-700 focus:outline-none focus:border-[var(--main-color)] text-right font-medium text-lg">
        </div>
      </div>
    </div>

    <div class="custom-card p-4 space-y-4 shadow-sm">
      <h3 class="text-md font-semibold text-gray-200 flex items-center gap-2 border-b border-gray-800 pb-2">
        <i class="fa-solid fa-receipt text-red-400"></i> รายจ่าย
      </h3>
      <div id="expenseList" class="space-y-3"></div>
      <div class="flex flex-col gap-3 mt-4 pt-2">
        <button onclick="addExpenseRow()" class="w-full py-3 bg-gray-800 hover:bg-gray-700 text-white rounded-xl border border-gray-600 text-sm font-medium flex items-center justify-center gap-2 transition shadow-sm">
          <i class="fa-solid fa-plus text-[var(--main-color)]"></i> เพิ่มบรรทัด
        </button>
        <button onclick="clearAllToday()" class="w-full py-3 bg-red-900/20 hover:bg-red-900/40 text-red-400 rounded-xl border border-red-800/50 text-sm font-medium flex items-center justify-center gap-2 transition">
          <i class="fa-solid fa-trash-can"></i> ล้างข้อมูลทั้งหมด
        </button>
      </div>
    </div>

    <button onclick="submitAllData()" class="w-full bg-[var(--main-color)] hover:bg-[var(--main-color-dark)] text-black text-lg font-bold py-4 rounded-xl flex items-center justify-center gap-2 shadow-lg mb-8 transition">
      🚀 ส่งยอดเข้า Google Sheet
    </button>
  </div>

  <script>
    // ==========================================
    // TODO: ใส่ Config Firebase ของคุณที่นี่
    // ==========================================
    const firebaseConfig = {
      apiKey: "AIzaSyBqQbM2GSAqcVyZooORwLqzGE380QAGWTo",
      authDomain: "grill-meat.firebaseapp.com",
      // บรรทัดด้านล่างนี้ผมเติมให้ เพราะในรูปมันมักจะบัคไม่ยอมโชว์ให้ครับ
      databaseURL: "https://grill-meat-default-rtdb.asia-southeast1.firebasedatabase.app", 
      projectId: "grill-meat",
      storageBucket: "grill-meat.firebasestorage.app",
      messagingSenderId: "209813792493",
      appId: "1:209813792493:web:463ca7210c23c7ab1ecee4",
      measurementId: "G-J47TF1HY0F"
    };
    
    // เริ่มต้นเชื่อมต่อ Firebase
    if (!firebase.apps.length) {
      firebase.initializeApp(firebaseConfig);
    }
    const db = firebase.database();

    // URL Web App จาก Google Apps Script (ส่งยอดจริง)
    const API_URL = "https://script.google.com/macros/s/AKfycbzvSJjBT4c2Jsl0U0UYynYkE5J1eFR6h1OHMzACtE0dAq8VPGJHWUWan4fkSQnea_5V/exec";

    // ฐานข้อมูลตัวเลือก
    const productUnits = {
      "แก๊สปิคนิค": "ถัง", "แก๊สถังใหญ่ 15 กิโล": "ถัง", "หัวแก๊สปิคนิค": "หัว", "ถุงร้อน 4.5x7 นิ้ว": "หิ้ว",
      "ถุง 5x8 นิ้ว": "หิ้ว", "ไม้เสียบ6นิ้ว": "แพ็ค", "ถุงหิ้ว 6x11": "หิ้ว", "ถุงหิ้ว 7x15": "หิ้ว",
      "ถุงมือยาง": "แพ็ค", "ถุงมือใส": "แพ็ค", "แหนม": "ถุง", "ไส้อั่วสมุนไพร": "แพ็ค", "หมูนมสด": "แพ็ค",
      "หมูหม่าล่า": "แพ็ค", "ไก่": "แพ็ค", "ริบอาย": "แพ็ค", "ตับ": "แพ็ค", "ไก่หม่าล่า": "แพ็ค",
      "ข้าวเหนียว": "กระสอบ", "ต้นตำหรับ": "แพ็ค", "หม่าล่า": "แพ็ค", "พริกไทยดำ": "แพ็ค", "พริกเกาหลี": "แพ็ค",
      "เสือร้องไห้": "แพ็ค"
    };
    const allProducts = Object.keys(productUnits).concat([
      "เงินเดือน แม็กซ์", "พิเศษ แม็กซ์", "โบนัส แม็กซ์",
      "ค่าเช่า ทาวน่ามาร์เก็ต", "ค่าขยะ ทาวน่ามาร์เก็ต", "ค่าไฟห้องแม๊กซ์"
    ]);

    window.onload = function() {
      const today = new Date();
      const offset = today.getTimezoneOffset() * 60000;
      const localISOTime = (new Date(today - offset)).toISOString().split('T')[0];
      
      document.getElementById('dateInput').value = localISOTime;
      document.getElementById('lockDateInput').value = localISOTime;
      fetchDateData(localISOTime);
    };

    function onDateChange() {
      const dateStr = document.getElementById('dateInput').value;
      if(!dateStr) return;
      document.getElementById('lockDateInput').value = dateStr;
      fetchDateData(dateStr);
    }

    function changeDateFromInput(val) {
      if(!val) return;
      document.getElementById('dateInput').value = val;
      onDateChange();
    }

    // ดึงข้อมูล (จะเช็คจาก Firebase ก่อน ถ้าไม่มีค่อยไปถาม Google Sheet)
    function fetchDateData(dateStr) {
      showLoading(true);
      
      // ดึงจาก Firebase (Draft)
      db.ref('drafts/' + dateStr).once('value').then((snapshot) => {
        const draft = snapshot.val();
        
        if (draft) {
          // ถ้ามี draft ใน Firebase ให้โหลดขึ้นมาเลย (เร็วมาก)
          renderData(draft);
          showLoading(false);
          if (draft.isSubmitted) {
            document.getElementById('lockScreen').classList.remove('hidden');
          } else {
            document.getElementById('lockScreen').classList.add('hidden');
          }
        } else {
          // ถ้าไม่มี ให้วิ่งไปดึงจาก GAS เผื่อเคยทำส่งไว้
          fetch(`${API_URL}?action=getData&date=${dateStr}`)
            .then(res => res.json())
            .then(response => {
              showLoading(false);
              if (response && response.success) {
                renderData(response.data);
                // เช็คประวัติการส่ง
                if (localStorage.getItem("submitted_" + dateStr) === "true") {
                  document.getElementById('lockScreen').classList.remove('hidden');
                } else {
                  document.getElementById('lockScreen').classList.add('hidden');
                }
              }
            }).catch(() => { showLoading(false); });
        }
      });
    }

    // นำข้อมูลลงหน้าจอ
    function renderData(data) {
      document.getElementById('cashInput').value = data.incomeCash || data.cash || '';
      document.getElementById('transferInput').value = data.incomeTransfer || data.transfer || '';
      document.getElementById('expenseList').innerHTML = "";
      
      if (data.expenses && data.expenses.length > 0) {
        data.expenses.forEach(exp => {
          addExpenseRow(exp.name, exp.amount, exp.unit, exp.price);
        });
      } else {
        addExpenseRow();
      }
    }

    // เพิ่มบรรทัดรายจ่าย (เปลี่ยนใช้ onchange แทน onblur เพื่อลดรอบการเซฟ)
    function addExpenseRow(name = "", amount = "", unit = "", price = "") {
      const container = document.getElementById('expenseList');
      const rowId = "row_" + Date.now() + Math.floor(Math.random() * 100);

      const div = document.createElement('div');
      div.id = rowId;
      div.className = "flex items-center gap-1 p-2 rounded-xl bg-[#252525] border border-gray-700";
      div.innerHTML = `
        <div class="grid grid-cols-12 gap-1 w-full">
          <div class="col-span-5 relative">
            <input type="text" value="${name}" oninput="handleSearchDropdown(this)" onkeydown="checkNextFocus(event, this, 'amount')" onchange="saveDraftToFirebase()"
                   placeholder="รายการ" class="w-full bg-[#1e1e1e] text-white px-2 py-2.5 rounded-lg border border-gray-600 focus:outline-none focus:border-[var(--main-color)] text-sm exp-name">
            <div class="dropdown-list hidden"></div>
          </div>
          <div class="col-span-2">
            <input type="number" value="${amount}" onkeydown="checkNextFocus(event, this, 'unit')" onchange="saveDraftToFirebase()"
                   placeholder="จำนวน" class="w-full bg-[#1e1e1e] text-white px-1 py-2.5 rounded-lg border border-gray-600 focus:outline-none focus:border-[var(--main-color)] text-sm text-center exp-amount">
          </div>
          <div class="col-span-2">
            <input type="text" value="${unit}" onkeydown="checkNextFocus(event, this, 'price')" onchange="saveDraftToFirebase()"
                   placeholder="หน่วย" class="w-full bg-[#1e1e1e] text-white px-1 py-2.5 rounded-lg border border-gray-600 focus:outline-none focus:border-[var(--main-color)] text-sm text-center exp-unit">
          </div>
          <div class="col-span-3">
            <input type="number" value="${price}" onkeydown="checkNextFocus(event, this, 'nextRow')" onchange="saveDraftToFirebase()"
                   placeholder="บาท" class="w-full bg-[#1e1e1e] text-white px-2 py-2.5 rounded-lg border border-gray-600 focus:outline-none focus:border-[var(--main-color)] text-sm text-right exp-price">
          </div>
        </div>
        <button onclick="removeRow('${rowId}')" class="text-gray-500 hover:text-red-400 p-2">
          <i class="fa-solid fa-xmark"></i>
        </button>
      `;
      container.appendChild(div);
    }

    function removeRow(rowId) {
      document.getElementById(rowId).remove();
      saveDraftToFirebase();
    }

    function handleSearchDropdown(input) {
      const dropdown = input.nextElementSibling;
      const query = input.value.trim().toLowerCase();
      if (!query) { dropdown.classList.add('hidden'); return; }
      const matched = allProducts.filter(p => p.toLowerCase().includes(query));
      if (matched.length === 0) { dropdown.classList.add('hidden'); return; }
      dropdown.innerHTML = matched.map(m => `<div class="p-3 hover:bg-[var(--main-color)] hover:text-black cursor-pointer border-b border-gray-700 text-sm text-white" onclick="selectDropdownItem('${m}', this)">${m}</div>`).join('');
      dropdown.classList.remove('hidden');
    }

    function selectDropdownItem(val, itemElem) {
      const dropdown = itemElem.parentElement;
      const nameInput = dropdown.previousElementSibling;
      nameInput.value = val;
      dropdown.classList.add('hidden');
      const row = nameInput.closest('.flex');
      const unitInput = row.querySelector('.exp-unit');
      if (productUnits[val]) { unitInput.value = productUnits[val]; }
      
      saveDraftToFirebase();
      row.querySelector('.exp-amount').focus();
    }

    function checkNextFocus(e, input, targetType) {
      if (e.key === 'Enter') {
        e.preventDefault();
        const row = input.closest('.flex');
        if (targetType === 'amount') row.querySelector('.exp-amount').focus();
        else if (targetType === 'unit') row.querySelector('.exp-unit').focus();
        else if (targetType === 'price') row.querySelector('.exp-price').focus();
        else if (targetType === 'nextRow') {
          const nextRowContainer = row.nextElementSibling;
          if (nextRowContainer) nextRowContainer.querySelector('.exp-name').focus();
          else {
            addExpenseRow();
            setTimeout(() => { document.getElementById('expenseList').lastElementChild.querySelector('.exp-name').focus(); }, 50);
          }
        }
      }
    }

    function clearAllToday() {
      if (confirm('ยืนยันล้างข้อมูลของวันนี้ทั้งหมด?')) {
        document.getElementById('cashInput').value = '';
        document.getElementById('transferInput').value = '';
        document.getElementById('expenseList').innerHTML = '';
        addExpenseRow();
        
        // ลบ Draft ออกจาก Firebase ด้วย
        const dateStr = document.getElementById('dateInput').value;
        db.ref('drafts/' + dateStr).remove();
      }
    }

    function gatherData() {
      const dateStr = document.getElementById('dateInput').value;
      const cash = document.getElementById('cashInput').value;
      const transfer = document.getElementById('transferInput').value;
      const expenses = [];
      document.querySelectorAll('#expenseList > div').forEach(row => {
        const name = row.querySelector('.exp-name').value;
        const amount = row.querySelector('.exp-amount').value;
        const unit = row.querySelector('.exp-unit').value;
        const price = row.querySelector('.exp-price').value;
        if (name || price) expenses.push({ name, amount, unit, price });
      });
      return { dateStr, cash, transfer, expenses };
    }

    // บันทึก Draft ลง Firebase อย่างรวดเร็ว
    function saveDraftToFirebase() {
      const data = gatherData();
      if (!data.dateStr) return;
      
      // ดึงสถานะปัจจุบันมาเช็คก่อน ถ้าล็อกอยู่จะไม่ให้เซฟทับมั่วๆ
      const isLocked = !document.getElementById('lockScreen').classList.contains('hidden');
      data.isSubmitted = isLocked;
      
      db.ref('drafts/' + data.dateStr).set(data);
    }

    // ส่งยอดเข้า Google Sheet และอัปเดตสถานะใน Firebase เป็น Submitted
    function submitAllData() {
      const data = gatherData();
      if (!data.dateStr) return alert("กรุณาเลือกวันที่ก่อนบันทึก");
      
      showLoading(true);
      fetch(API_URL, {
        method: 'POST',
        body: JSON.stringify(data),
        headers: { 'Content-Type': 'text/plain;charset=utf-8' }
      })
      .then(res => res.json())
      .then(res => {
        showLoading(false);
        if (res.success) {
          // ส่งสำเร็จ ล็อคหน้าจอ และอัปเดตลง Firebase ว่าส่งแล้ว
          localStorage.setItem("submitted_" + data.dateStr, "true");
          data.isSubmitted = true;
          db.ref('drafts/' + data.dateStr).set(data);
          
          document.getElementById('successModal').classList.remove('hidden');
        } else {
          alert('เกิดข้อผิดพลาดในการบันทึก: ' + res.error);
        }
      })
      .catch(error => {
        showLoading(false);
        alert('เกิดข้อผิดพลาดในการเชื่อมต่อเซิร์ฟเวอร์');
      });
    }

    function unlockForEdit() {
      const dateStr = document.getElementById('dateInput').value;
      localStorage.removeItem("submitted_" + dateStr);
      
      // ปลดล็อคใน Firebase ด้วย
      db.ref('drafts/' + dateStr).update({ isSubmitted: false });
      
      document.getElementById('lockScreen').classList.add('hidden');
    }

    function closeSuccessModal() {
      document.getElementById('successModal').classList.add('hidden');
      document.getElementById('lockScreen').classList.remove('hidden');
    }

    function nextDayAction() {
      document.getElementById('successModal').classList.add('hidden');
      const dateVal = document.getElementById('dateInput').value;
      const dt = new Date(dateVal);
      dt.setDate(dt.getDate() + 1);
      const offset = dt.getTimezoneOffset() * 60000;
      const nextDateStr = (new Date(dt - offset)).toISOString().split('T')[0];
      
      document.getElementById('dateInput').value = nextDateStr;
      document.getElementById('lockDateInput').value = nextDateStr;
      fetchDateData(nextDateStr);
    }

    function showLoading(show) {
      const overlay = document.getElementById('loadingOverlay');
      if (show) overlay.classList.remove('hidden');
      else overlay.classList.add('hidden');
    }
  </script>
</body>
</html>
